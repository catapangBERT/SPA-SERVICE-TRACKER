    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Message1').first().json;\nconst rows = $input.all();\n\nconst clientNameInput = parsed.clientName.toLowerCase().trim();\nconst serviceInput = parsed.service.toLowerCase().trim();\n\nlet match = null;\n\nfor (const row of rows) {\n  const rowName = (row.json['Client Name'] || '').toLowerCase().trim();\n  const rowService = (row.json['Service'] || '').toLowerCase().trim();\n  if (rowName === clientNameInput && rowService === serviceInput) {\n    match = row.json;\n    break;\n  }\n}\n\nif (!match) {\n  return [{\n    json: {\n      scheduleFound: false,\n      chatId: parsed.chatId,\n      clientName: parsed.clientName,\n      service: parsed.service,\n      status: parsed.status,\n      time: parsed.time,\n      lastUpdated: parsed.lastUpdated,\n      replyMsg: `Γ¥î No schedule found for \"${parsed.clientName}\" with service \"${parsed.service}\".\\nPlease check the name and service and try again.`\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    scheduleFound: true,\n    chatId: parsed.chatId,\n    clientName: parsed.clientName,\n    service: parsed.service,\n    status: parsed.status,\n    time: parsed.time,\n    lastUpdated: parsed.lastUpdated,\n    scheduledDate: match['Date'] || '',\n    scheduledTime: match['Time'] || '',\n    location: match['Location'] || ''\n  }\n}];"
      },
