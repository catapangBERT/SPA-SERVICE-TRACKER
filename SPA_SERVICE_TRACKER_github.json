    {
      "parameters": {
        "jsCode": "const text = $input.first().json.message.text;\nconst chatId = $input.first().json.message.chat.id;\n\nif (!text) throw new Error('No message text received.');\n\nconst parts = text.split(',').map(p => p.trim());\n\nif (parts.length < 4) {\n  return [{ json: { error: true, chatId, errorMsg: 'Γ¥î Wrong format!\\nUse: Name, Service, Status, Time\\nExample: Jennifer, Swedish Massage, Done, 7:30' } }];\n}\n\nconst validStatuses = ['done', 'cancelled', 'rescheduled'];\nconst status = parts[2].toLowerCase();\n\nif (!validStatuses.includes(status)) {\n  return [{ json: { error: true, chatId, errorMsg: 'Γ¥î Invalid status. Use: Done, Cancelled, or Rescheduled' } }];\n}\n\nreturn [{\n  json: {\n    error: false,\n    clientName: parts[0],\n    service: parts[1],\n    status: parts[2].charAt(0).toUpperCase() + parts[2].slice(1).toLowerCase(),\n    time: parts[3],\n    chatId,\n    lastUpdated: new Date().toLocaleString('en-PH', { timeZone: 'Asia/Manila' })\n  }\n}];"
      },
