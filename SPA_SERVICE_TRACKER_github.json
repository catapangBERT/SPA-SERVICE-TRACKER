      "parameters": {
        "jsCode": "const parsed = $('Check In SCHEDULES').first().json;\nconst rows = $input.all();\n\nconst clientNameInput = parsed.clientName.toLowerCase().trim();\nconst serviceInput = parsed.service.toLowerCase().trim();\n\nlet matchIndex = -1;\nlet alreadyUpdated = false;\n\nfor (let i = 0; i < rows.length; i++) {\n  const rowName = (rows[i].json['Client Name'] || '').toLowerCase().trim();\n  const rowService = (rows[i].json['Service'] || '').toLowerCase().trim();\n  const rowStatus = (rows[i].json['Status'] || '').toLowerCase().trim();\n\n  if (rowName === clientNameInput && rowService === serviceInput) {\n    matchIndex = i;\n    if (rowStatus === parsed.status.toLowerCase()) {\n      alreadyUpdated = true;\n    }\n    break;\n  }\n}\n\nif (alreadyUpdated) {\n  return [{\n    json: {\n      trackerFound: true,\n      alreadyUpdated: true,\n      chatId: parsed.chatId,\n      clientName: parsed.clientName,\n      service: parsed.service,\n      status: parsed.status,\n      time: parsed.time,\n      lastUpdated: parsed.lastUpdated,\n      replyMsg: `ΓÜá∩╕Å Already updated!\\n\\n≡ƒæñ ${parsed.clientName} - ${parsed.service} is already marked as \"${parsed.status}\".\\nNo changes made.`\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    trackerFound: matchIndex !== -1,\n    alreadyUpdated: false,\n    rowIndex: matchIndex !== -1 ? matchIndex + 2 : null,\n    chatId: parsed.chatId,\n    clientName: parsed.clientName,\n    service: parsed.service,\n    status: parsed.status,\n    time: parsed.time,\n    lastUpdated: parsed.lastUpdated\n  }\n}];"
      },
